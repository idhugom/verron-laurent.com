---
import '@fontsource-variable/fredoka';
import '@fontsource-variable/plus-jakarta-sans';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'Verron-laurent.com — des conseils pratiques, guides détaillés et comparatifs pour faire les bons choix au quotidien.',
  image = '/logo.png',
  type = 'website',
  publishedTime,
  modifiedTime,
  noindex = false,
  jsonLd,
} = Astro.props;

const site = Astro.site ?? new URL('https://www.verron-laurent.com');
const canonical = new URL(Astro.url.pathname, site).href.replace(/\/$/, '') || site.href;
const ogImage = new URL(image, site).href;
const fullTitle = title.includes('Verron') ? title : `${title} · Verron-laurent.com`;

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Verron-laurent.com',
  url: site.href,
  logo: new URL('/logo.png', site).href,
  slogan: 'Mes conseils',
};
const jsonLdArray = [orgLd, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <meta name="theme-color" content="#0054e4" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:site_name" content="Verron-laurent.com" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="alternate" type="application/rss+xml" title="Verron-laurent.com" href="/rss.xml" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLdArray)} />

    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">Aller au contenu</a>

    <!-- Fond décoratif animé -->
    <div class="page-bg" aria-hidden="true">
      <span class="blob blob--1" style="background:var(--vl-sky)"></span>
      <span class="blob blob--2" style="background:var(--vl-peach)"></span>
      <span class="blob blob--3" style="background:var(--vl-blue)"></span>
    </div>

    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <button class="to-top" aria-label="Remonter en haut" data-to-top>
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7" /></svg>
    </button>

    <style>
      .skip-link {
        position: fixed;
        top: -60px;
        left: 12px;
        z-index: 200;
        background: var(--vl-navy);
        color: #fff;
        padding: 0.6em 1em;
        border-radius: 0 0 12px 12px;
        transition: top 0.2s;
      }
      .skip-link:focus {
        top: 0;
        color: #fff;
      }

      .page-bg {
        position: fixed;
        inset: 0;
        z-index: -1;
        overflow: hidden;
      }
      .page-bg .blob {
        position: absolute;
        filter: blur(70px);
        opacity: 0.28;
      }
      .blob--1 {
        width: 42vw;
        height: 42vw;
        top: -10vw;
        left: -8vw;
      }
      .blob--2 {
        width: 34vw;
        height: 34vw;
        top: 32vh;
        right: -10vw;
        animation-name: floatX;
        animation-duration: 18s;
      }
      .blob--3 {
        width: 30vw;
        height: 30vw;
        bottom: -12vw;
        left: 28vw;
        opacity: 0.16;
        animation-duration: 20s;
      }

      .to-top {
        position: fixed;
        right: clamp(14px, 3vw, 30px);
        bottom: clamp(14px, 3vw, 30px);
        z-index: 90;
        width: 50px;
        height: 50px;
        display: grid;
        place-items: center;
        border: none;
        border-radius: 50%;
        background: var(--grad-primary);
        color: #fff;
        box-shadow: var(--shadow-glow);
        opacity: 0;
        transform: translateY(20px) scale(0.7);
        pointer-events: none;
        transition: opacity 0.3s, transform 0.3s var(--ease-spring);
      }
      .to-top.is-shown {
        opacity: 1;
        transform: none;
        pointer-events: auto;
      }
      .to-top:hover {
        transform: translateY(-3px) scale(1.08);
      }
    </style>

    <script>
      // Scroll reveal
      const setupReveal = () => {
        const els = document.querySelectorAll('[data-reveal]');
        if (!('IntersectionObserver' in window) || !els.length) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        els.forEach((el) => io.observe(el));
      };

      // Bouton retour haut
      const setupToTop = () => {
        const btn = document.querySelector('[data-to-top]');
        if (!btn) return;
        const onScroll = () => btn.classList.toggle('is-shown', window.scrollY > 600);
        window.addEventListener('scroll', onScroll, { passive: true });
        btn.addEventListener('click', () =>
          window.scrollTo({ top: 0, behavior: 'smooth' })
        );
        onScroll();
      };

      const init = () => {
        setupReveal();
        setupToTop();
      };
      document.addEventListener('astro:page-load', init);
    </script>
  </body>
</html>
