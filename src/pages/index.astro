---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const posts = (await getCollection('posts')).sort((a, b) =>
  b.data.date > a.data.date ? 1 : -1
);
const featured = posts[0];
const recent = posts.slice(1, 10);

const topicCount = new Map();
for (const p of posts) for (const t of p.data.topics) topicCount.set(t, (topicCount.get(t) || 0) + 1);
const topTopics = [...topicCount.entries()].sort((a, b) => b[1] - a[1]).slice(0, 14);

const values = [
  { icon: '🎯', title: 'Des conseils qui vont droit au but', text: 'Chaque guide répond concrètement à votre question, sans jargon ni remplissage.' },
  { icon: '🔍', title: 'Comparatifs et critères clairs', text: 'Tableaux, avantages/inconvénients et points de vigilance pour décider sereinement.' },
  { icon: '💡', title: 'Du pratique, vraiment utile', text: 'Des méthodes, des étapes et des astuces applicables tout de suite au quotidien.' },
];
---

<BaseLayout title="Verron-laurent.com — Des conseils pratiques pour faire les bons choix">
  <!-- HERO -->
  <section class="hero">
    <span class="blob blob--a" aria-hidden="true"></span>
    <span class="blob blob--b" aria-hidden="true"></span>
    <span class="hero-shape hero-shape--ring" aria-hidden="true"></span>
    <span class="hero-shape hero-shape--star" aria-hidden="true">✦</span>
    <span class="hero-shape hero-shape--dot" aria-hidden="true"></span>

    <div class="container hero__inner">
      <p class="eyebrow" data-reveal>✨ Mes conseils, en mieux</p>
      <h1 class="hero__title" data-reveal style="--reveal-delay:.05s">
        Faites les <span class="gradient-text">bons choix</span><br />au quotidien.
      </h1>
      <p class="hero__lead" data-reveal style="--reveal-delay:.12s">
        Assurance, auto, moto, mode, maison, voyage… Des guides pratiques, comparatifs et honnêtes
        pour trancher en confiance — écrits pour être vraiment utiles.
      </p>
      <div class="hero__actions" data-reveal style="--reveal-delay:.18s">
        <a href="/articles" class="btn">Explorer les conseils</a>
        <a href="/themes" class="btn btn--ghost">Parcourir par thème</a>
      </div>
      <div class="hero__stats" data-reveal style="--reveal-delay:.24s">
        <div><strong>{posts.length}+</strong><span>guides publiés</span></div>
        <div><strong>{topTopics.length}+</strong><span>thématiques</span></div>
        <div><strong>100%</strong><span>conseils testés</span></div>
      </div>
    </div>
    <div class="hero-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 100" preserveAspectRatio="none"><path d="M0,60 C240,10 480,10 720,50 C960,90 1200,90 1440,45 L1440,100 L0,100 Z" fill="var(--vl-surface)"></path></svg>
    </div>
  </section>

  <!-- FEATURED + RECENT -->
  <section class="section home-articles">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <p class="eyebrow">📚 Derniers conseils</p>
          <h2>Fraîchement publiés</h2>
        </div>
        <a href="/articles" class="section-head__link">Tout voir <span aria-hidden="true">→</span></a>
      </div>

      <div class="home-grid">
        {
          featured && (
            <PostCard
              slug={featured.data.slug}
              title={featured.data.title}
              excerpt={featured.data.excerpt}
              heroImage={featured.data.heroImage}
              heroAlt={featured.data.heroAlt}
              topics={featured.data.topics}
              readingMinutes={featured.data.readingMinutes}
              featured={true}
            />
          )
        }
        {
          recent.map((p, i) => (
            <PostCard
              slug={p.data.slug}
              title={p.data.title}
              excerpt={p.data.excerpt}
              heroImage={p.data.heroImage}
              heroAlt={p.data.heroAlt}
              topics={p.data.topics}
              readingMinutes={p.data.readingMinutes}
              index={i}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- THEMES -->
  {
    topTopics.length > 0 && (
      <section class="section themes-teaser">
        <div class="container">
          <div class="section-head section-head--center" data-reveal>
            <p class="eyebrow">🧭 Explorer</p>
            <h2>Trouvez le conseil qu'il vous faut</h2>
          </div>
          <div class="topic-cloud" data-reveal>
            {topTopics.map(([t, n]) => (
              <a href={`/themes#${t.replace(/\s+/g, '-')}`} class="topic-pill">
                {t}
                <span>{n}</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- VALUES -->
  <section class="section values">
    <div class="container">
      <div class="section-head section-head--center" data-reveal>
        <p class="eyebrow">💙 Pourquoi Verron-laurent ?</p>
        <h2>Des conseils pensés pour vous être vraiment utiles</h2>
      </div>
      <div class="values__grid">
        {
          values.map((v, i) => (
            <div class="value-card" data-reveal style={`--reveal-delay:${i * 0.08}s`}>
              <span class="value-card__icon">{v.icon}</span>
              <h3>{v.title}</h3>
              <p>{v.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="home-cta" data-reveal>
        <span class="home-cta__blob" aria-hidden="true"></span>
        <h2>Une question, un choix à faire&nbsp;?</h2>
        <p>Des centaines de guides pratiques vous attendent. Commencez à explorer dès maintenant.</p>
        <a href="/articles" class="btn btn--accent">Découvrir tous les conseils</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--grad-hero);
    padding-top: clamp(3rem, 6vw, 6rem);
    padding-bottom: clamp(5rem, 9vw, 8rem);
    text-align: center;
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    max-width: 880px;
  }
  .hero__title {
    font-size: clamp(2.7rem, 1.4rem + 5.5vw, 5.2rem);
    line-height: 1.02;
    margin: 1.2rem 0 1.3rem;
  }
  .hero__lead {
    font-size: clamp(1.05rem, 0.98rem + 0.5vw, 1.3rem);
    color: var(--vl-ink-soft);
    max-width: 620px;
    margin: 0 auto;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    justify-content: center;
    margin-top: 2rem;
  }
  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(1.5rem, 5vw, 3.5rem);
    margin-top: 3rem;
  }
  .hero__stats div {
    display: flex;
    flex-direction: column;
  }
  .hero__stats strong {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.8rem, 1.3rem + 1.6vw, 2.6rem);
    background: var(--grad-text);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    line-height: 1;
  }
  .hero__stats span {
    font-size: 0.85rem;
    color: var(--vl-ink-muted);
    margin-top: 0.3rem;
  }

  .hero .blob {
    filter: blur(60px);
    z-index: 1;
  }
  .blob--a {
    width: 32vw;
    height: 32vw;
    background: var(--vl-sky);
    top: -6vw;
    left: -4vw;
    opacity: 0.4;
  }
  .blob--b {
    width: 26vw;
    height: 26vw;
    background: var(--vl-peach);
    bottom: 4vw;
    right: -3vw;
    opacity: 0.32;
    animation-name: floatX;
    animation-duration: 16s;
  }
  .hero-shape {
    position: absolute;
    z-index: 1;
  }
  .hero-shape--ring {
    width: 90px;
    height: 90px;
    border: 12px solid var(--vl-sky);
    border-radius: 50%;
    opacity: 0.55;
    top: 22%;
    right: 12%;
    animation: float 9s ease-in-out infinite;
  }
  .hero-shape--star {
    font-size: 2.4rem;
    color: var(--vl-peach);
    top: 30%;
    left: 10%;
    animation: wiggle 5s ease-in-out infinite;
  }
  .hero-shape--dot {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--vl-blue);
    bottom: 22%;
    left: 18%;
    opacity: 0.5;
    animation: float 7s ease-in-out infinite;
  }
  .hero-wave {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    z-index: 2;
  }
  .hero-wave svg {
    width: 100%;
    height: clamp(50px, 7vw, 100px);
    display: block;
  }

  /* SECTION HEAD */
  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.4rem;
  }
  .section-head h2 {
    margin-top: 0.6rem;
  }
  .section-head--center {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .section-head__link {
    font-family: var(--font-display);
    font-weight: 600;
    white-space: nowrap;
    padding-bottom: 0.4rem;
  }

  .home-articles {
    background: var(--vl-surface);
  }
  .home-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 1.6rem;
  }

  /* THEMES */
  .topic-cloud {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.8rem;
  }
  .topic-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.02rem;
    color: var(--vl-navy);
    background: var(--vl-surface);
    border: 1px solid var(--vl-line);
    padding: 0.6em 1.1em;
    border-radius: var(--radius-pill);
    text-transform: capitalize;
    box-shadow: var(--shadow-sm);
    transition: transform 0.25s var(--ease-spring), border-color 0.2s, color 0.2s;
  }
  .topic-pill span {
    display: grid;
    place-items: center;
    min-width: 1.6em;
    height: 1.6em;
    font-size: 0.75rem;
    font-weight: 700;
    color: #fff;
    background: var(--vl-blue);
    border-radius: 50%;
  }
  .topic-pill:hover {
    transform: translateY(-4px) rotate(-1deg);
    border-color: var(--vl-sky);
    color: var(--vl-blue-700);
  }

  /* VALUES */
  .values__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.6rem;
  }
  .value-card {
    background: var(--vl-surface);
    border: 1px solid var(--vl-line);
    border-radius: var(--radius-lg);
    padding: 2rem 1.8rem;
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s var(--ease-spring), box-shadow 0.3s;
  }
  .value-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
  }
  .value-card__icon {
    display: grid;
    place-items: center;
    width: 60px;
    height: 60px;
    font-size: 1.8rem;
    background: var(--grad-hero);
    border: 1px solid var(--vl-blue-100);
    border-radius: 18px;
    margin-bottom: 1.2rem;
  }
  .value-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.6rem;
  }
  .value-card p {
    color: var(--vl-ink-muted);
  }

  /* CTA */
  .home-cta {
    position: relative;
    overflow: hidden;
    text-align: center;
    background: var(--vl-navy);
    border-radius: var(--radius-xl);
    padding: clamp(2.5rem, 5vw, 4.5rem) var(--gutter);
  }
  .home-cta h2 {
    color: #fff;
    font-size: clamp(1.6rem, 1.2rem + 1.6vw, 2.4rem);
  }
  .home-cta p {
    color: #b9c5ec;
    max-width: 48ch;
    margin: 0.8rem auto 1.8rem;
  }
  .home-cta__blob {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--vl-blue) 0%, transparent 70%);
    opacity: 0.55;
    top: -180px;
    right: -120px;
    pointer-events: none;
  }

  @media (max-width: 640px) {
    .section-head {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
